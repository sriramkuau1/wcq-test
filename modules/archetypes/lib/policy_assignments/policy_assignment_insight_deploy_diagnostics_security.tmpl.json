{
  "type": "Microsoft.Authorization/policyAssignments",
  "apiVersion": "2024-04-01",
  "name": "Deploy-Diag-Security",
  "location": "${default_location}",
  "dependsOn": [],
  "identity": {
    "type": "SystemAssigned"
  },
  "properties": {
    "description": "Deploy diagnostic settings to send Security category logs to Log Analytics workspace",
    "displayName": "Deploy Diagnostic Settings for Security Logs",
    "policyDefinitionId": "${root_scope_resource_id}/providers/Microsoft.Authorization/policyDefinitions/Deploy-Diag-Security",
    "enforcementMode": "Default",
    "nonComplianceMessages": [
      {
        "message": "Security diagnostic settings {enforcementMode} be deployed to send logs to Log Analytics workspace."
      }
    ],
    "parameters": {
      "logAnalyticsWorkspaceId": {
        "value": "/subscriptions/00000000-0000-0000-0000-000000000000/resourcegroups/${root_scope_id}-mgmt/providers/Microsoft.OperationalInsights/workspaces/${root_scope_id}-la"
      },
      "settingName": {
        "value": "security-diagnostics"
      },
      "effect": {
        "value": "DeployIfNotExists"
      }
    },
    "scope": "${current_scope_resource_id}",
    "notScopes": []
  }
}
